FROM devilbox/php-fpm-5.3:latest

RUN echo 'Europe/Istanbul' > /etc/timezone

RUN set -eux \
    && echo 'Acquire::Check-Valid-Until no;' > /etc/apt/apt.conf.d/99no-check-valid-until \
    && { \
    echo "deb [trusted=yes] http://archive.debian.org/debian/ jessie main non-free contrib"; \
    echo "deb-src [trusted=yes] http://archive.debian.org/debian/ jessie main non-free contrib"; \
    echo "deb [trusted=yes] http://archive.debian.org/debian-security/ jessie/updates main non-free contrib"; \
    echo "deb-src [trusted=yes] http://archive.debian.org/debian-security/ jessie/updates main non-free contrib"; \
    } > /etc/apt/sources.list

RUN apt update
RUN apt full-upgrade -y --force-yes
RUN apt-get autoremove -y --force-yes
RUN apt install -y --force-yes \
    php5-pgsql \
    php5-cli \
    php5-common \
    php5-mysql \
    php5-mcrypt \
    libpq-dev \
    gcc \
    make \
    autoconf \
    libc-dev \
    pkg-config

RUN docker-php-ext-install pgsql pdo_pgsql

EXPOSE 9000

CMD ["php-fpm"]
